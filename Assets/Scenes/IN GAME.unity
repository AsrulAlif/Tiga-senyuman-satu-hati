      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: '"(Jalan di samping, agak dekat sedikit)"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Tapi ini serius aku boleh ke rumah kamu Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Tentu saja boleh
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Kamu juga tidak usah ragu kalau kamu mau sesuatu dari ku
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: "Aku cuma\u2026 tidak terbiasa tiba-tiba di ajak ke rumah teman"
