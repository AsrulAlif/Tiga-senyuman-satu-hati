      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: "Eh tapi serius deh\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Kamu tuh enak diajak ngobrol.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
