  - dialogueID: Miiyu Bulan 6 event part 2
    dialogueSteps:
    - sentenceText: Oh iya Miyu kalau kamu tidak keberatan kita bisa belajar di rumah
        aku kalau kamu mau?
      voiceClip: {fileID: 0}
