  - dialogueID: Hikari 5
    dialogueSteps:
    - sentenceText: Sekolah ini sepertinya menarik ya? Banyak hal baru buatku
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: 'Bener banget! Aku bisa kasih tau spot-spot seru kalau mau. '
