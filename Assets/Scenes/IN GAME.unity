      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 0
    - sentenceText: '"Apa aku harus minta maaf sama Miyu?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 0
    choices:
    - choiceText: Ajak makan bareng Miyu dan minta maaf
      nextDialogueID: Miyu Bulan 2 event 1 part 4+
