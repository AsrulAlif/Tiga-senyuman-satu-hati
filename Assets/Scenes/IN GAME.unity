      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Iya juga ya.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: KAN...?! Aku juga mikir gitu!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: "Awalnya aku kira kamu itu orangnya bakal diem terus gitu\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Maksudnya?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: "Kayak\u2026 susah diajak ngobrol."
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Eh ternyata engga
      voiceClip: {fileID: 0}
