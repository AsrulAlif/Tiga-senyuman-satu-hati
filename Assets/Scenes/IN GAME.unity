    - sentenceText: Lu sehat kan
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Sehat ko
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Heem.... Kalo gitu cerita nya cuman ada 2 ya itu..
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
