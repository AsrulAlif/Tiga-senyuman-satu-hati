      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 0}
      changeBackground: 0
    - sentenceText: Kalo kamu bilang seenak itu mungkin kita punya lidah yang sama
