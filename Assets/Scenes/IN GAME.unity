      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Apa kamu serius?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Aku belum pernah mengerjakan pr bareng orang lain
