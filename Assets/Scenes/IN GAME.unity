  - dialogueID: Maya Bulan 1 event part 3
    dialogueSteps:
    - sentenceText: Di mana ini?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Loh, kok bisa ada orang di sini?
      voiceClip: {fileID: 8300000, guid: a635fa27c446c5e4bb267525b0cbde0b, type: 3}
      speakingCharacterKey: Maya
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Biasanya ini tidak terjadi.
      voiceClip: {fileID: 8300000, guid: 80ef65c8e431f6c4f82b6ece1b3a5b6a, type: 3}
      speakingCharacterKey: Maya
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Mungkin ini hanya kebetulan.
      voiceClip: {fileID: 8300000, guid: 246f0b0deea3939458b994534d5663ca, type: 3}
      speakingCharacterKey: Maya
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Ka-kamu siapa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Di mana kamu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Tenang saja, kamu sekarang berada di dunia mimpi.
      voiceClip: {fileID: 8300000, guid: 13c41270ba4eca8449e3f8b038524941, type: 3}
      speakingCharacterKey: Maya
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Sepertinya kamu sangat lelah di dunia sana.
      voiceClip: {fileID: 8300000, guid: c38a4ec8b678d5b4cb2820645d9f4512, type: 3}
      speakingCharacterKey: Maya
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Beristirahatlah di sini sebentar dan tutup matamu.
      voiceClip: {fileID: 8300000, guid: fd8fd1cc8be2f8344a5a78028aadeb8d, type: 3}
      speakingCharacterKey: Maya
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: ...
      nextDialogueID: Maya Bulan 1 event part 4
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
