      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Hehehe... Aku jadi malu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: '"Ajak kencan"'
