      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Miiyu Bulan 4 event part 3
    dialogueSteps:
    - sentenceText: Oh iya Pemain apa kamu sudah siap nanti?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Siap apa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Memangnya ada apa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kamu benar-benar tidak tahu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kan 2 bulan lagi kita UTS
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kamu serius
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kamu tidak bohong kan?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kamu serius
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kenapa aku harus berbohong
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Berarti kita harus belajar bersama buat UTS nanti?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Biar lebih gampang kalau ada yang salah bisa saling bantu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: '"(Kaget)" kamu mau belajar bersama bersama aku?'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Tentu saja kita kan sudah pernah menggerjakan tugas bersama
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Apa jangan-jangan kamu sudah punya rencana dengan orang lain?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: '"(Kaget dan senang)" E-eh?!, tidak kok aku baru di ajak sama
        kamu saja'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: "B-boleh sekali\u2026 aku malah senang sekali. Kalau sama kamu,
        mungkin aku bisa lebih semangat"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kalau gitu, kita harus tentuin tempat dan waktunya, ya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Bagaimana kalau perpustakaan seperti biasa
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Boleh sih tapi kan pasti akan ramai
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kalau begitu bagaimana pas selesai jam sekolah kita ke perpustakaan
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Aku yakin akan sepi dan sekolah di tutup hingga sore harusnya
        kita punya beberapa jam untuk belajar bersama
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Kamu kelihatan nya semangat sekali
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Ma...af ini pertama kalinya aku belajar bersama sama orang lain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Justru aku senang, Tapi coba aku pikir kan dulu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Terima ajakan Miyu
      nextDialogueID: Miiyu Bulan 4 event part 4
      moodTargetHeroine: 3
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain dan Miyu pun Merencanakan belajar bersama untuk
        nanti mereka UTS
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Aku mau belajar sendiri kali ini
      nextDialogueID: Miiyu Bulan 4 event part 4-
      moodTargetHeroine: 3
      moodChangeAmount: -3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Karena Pemain menolak ajakan Miyu, Miyu langsung menundukan
        kepala nya
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
