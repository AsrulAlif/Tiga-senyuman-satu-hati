      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99450402e96793240a00bd1e96c1861b, type: 3}
      changeBackground: 1
    - sentenceText: Lumayan sering kalau aku bosan di rumah biasa nya aku main keluar
