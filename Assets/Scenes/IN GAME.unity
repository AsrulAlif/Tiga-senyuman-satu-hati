  - dialogueID: Miiyu Bulan 8 event part 1
    dialogueSteps:
    - sentenceText: Seperti nya kamu butuh bantuan Miyu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Owh ternyata kamu Pemain
