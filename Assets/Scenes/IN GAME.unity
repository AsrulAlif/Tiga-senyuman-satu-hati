  - dialogueID: Miyu Bulan 2 event 1 part 4+
    dialogueSteps:
    - sentenceText: '"aku belum makan bareng sama Miyu dan minta maaf"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"Apa aku bawa bekel ya? atau pakai uang jajan tabungan ku?"'
      voiceClip: {fileID: 0}
