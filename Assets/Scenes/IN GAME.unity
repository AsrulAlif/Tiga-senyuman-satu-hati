      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 49998e9cc462cf946ab11720bec20e53, type: 3}
      changeBackground: 1
    - sentenceText: "Aku sedikit gugup kaerna aku belum pernah ke museum\u2026 bersama
