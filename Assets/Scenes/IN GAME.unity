  - dialogueID: Yumi Bulan 5 event part 2
    dialogueSteps:
    - sentenceText: Oh iya Yumi kalo kamu ga keberatan apa kamu mau pulang bareng?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kenapa tiba-tiba?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Ini udah lumayan ingin gelap loh
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kamu yakin pulang sendiri?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: 'I...iya udah deh '
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Gara gara kamu bilang begitu kamu harus tanggung jawap ya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aman saja
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Ayo kita jalan
      nextDialogueID: Yumi Bulan 5 event part 3
      moodTargetHeroine: 2
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain dan Yumi setelah mereka belajar bareng mereka
        pun pulang bareng
