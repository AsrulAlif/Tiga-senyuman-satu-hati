    - sentenceText: ...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Marah close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Oke aku tau kamu marah karena kemarin aku meninggal kan mu di
        kantin sendirian
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: dan aku minta maaf karena meninggal kan mu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
