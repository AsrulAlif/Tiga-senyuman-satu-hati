      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 0}
      changeBackground: 0
    - sentenceText: Sepertinya seru. Kamu kelihatan udah akrab banget sama sekolah
        ini
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Tentu dong! Aku tipe orang yang gampang betah di mana aja. Yuk
        nanti aku ajak kamu keliling.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 0}
      changeBackground: 0
    - sentenceText: Serius? Wah, makasih banget
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 7f5483e24d566cc4b9ccf586e5935cf1, type: 3}
      changeBackground: 1
    - sentenceText: Haha! Gampang, santai aja!
