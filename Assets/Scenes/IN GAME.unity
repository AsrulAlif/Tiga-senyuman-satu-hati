  - dialogueID: Miiyu Bulan 6 event part 6
    dialogueSteps:
    - sentenceText: Oh iya Miyu apa kamu ada rencana nanti setelah UTS
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Tidak ada memang kenapa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Kalo kamu mau gimana sebagai perayaan kita pergi ke suatu tempat
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Gimana kamu mau ga Miyu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"(kaget kebingungan)"Eh?!... kamu serius ini?'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Serius dong kita udah susah payah tau masa ga di rayain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Tapi kemana ya?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Gimana.. kalo Museum
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Aku sempat dengar kalo di museum bakalan ada pameran bersejarah
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Kalo gitu kita putuskan ya ke museum nanti
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Tunggu dulu-tunggu dulu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Kenapa kamu langsung menerima nya"(Muka cemas)"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Ya karena aku baru di daerah ini jadi aku tidak tau apa-apa yang
        ada di daerah ini tuh apa aja
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Makanya aku terima langsung saran mu,aku juga yakin pasti seru
        ko
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Aku juga penasaran denan Museun daerah ini
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Serius tidak apa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Iya serius
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Kalo begitu....
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Terima kasih ya Pemain :)
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
