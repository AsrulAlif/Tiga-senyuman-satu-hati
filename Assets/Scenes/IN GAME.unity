  - dialogueID: Hkari Bulan 6 event part 4
    dialogueSteps:
    - sentenceText: Sebelum kamu pulang aku mau tanya sesewatu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
