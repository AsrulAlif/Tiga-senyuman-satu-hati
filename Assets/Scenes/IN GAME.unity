  - dialogueID: Yumi Bulan 2 event 1 part 1
    dialogueSteps:
    - sentenceText: Halooo yumi
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Ini sudah istirahat looo
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kamu tidak istirahat?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aku tidak bisa istirahat sekarang
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Jadi jangan ganggu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Mau aku bantu lagi?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Boleh saja tapi nanti kamu tidak istirahat nanti
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Santai saja sekalian aku hanya mau tanya beberapa kok
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Ngomong-ngomong, kamu punya hobi tidak? atau suka apa gitu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Hah? Kenapa kamu tiba-tiba tanya gitu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "\u2026Y-ya aku suka koleeksi barang barang yang lucu seperti
        boneka atau gantungan kunci sih\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Tapi jangan bilang siapa-siapa!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Haha, tenang saja. Rahasiamu aman sama aku
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "Hmph! Jangan sok akrab\u2026 tapi makasih"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: '"Ingat ingat apa yang Yumi suka"'
      nextDialogueID: Yumi Bulan 2 event 1 part 2
      moodTargetHeroine: 2
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: '"Pemain dan Yumi pun selalu berbincang apa yang mereka
        sukai di saat jam istirahat"'
