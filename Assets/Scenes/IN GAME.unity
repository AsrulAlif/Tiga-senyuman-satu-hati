  - dialogueID: Miiyu Bulan 9 event part 2-
    dialogueSteps:
    - sentenceText: '"Festival semalam sangat membosankan"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"Aku penasaran apa miyu ke festival atau tidak kemarin"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: '"Hem aku kok tidak melihat dia masuk ya?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: '"Di perpustakaan juga tidak ada"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: '"Di mana ya kira kira miyu"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Wadap Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Muka lesu sekali kenapa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Aku sedang mencari Miyu, apa kamu lihat Basrul?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Geregadewm lu tidak tahu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Miyu kan akhir akhir ini dia tidak masuk
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Rumor nya dia mau pindah sekolah
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Maaf ya kawan tidak ngabarin dari awal
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Iya tidak papa Basrul trimakasih ya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Aman saja gua ke klub dulu ya dadah Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Dadah...
      nextDialogueID: Miiyu Bulan 9 event part 3-
      moodTargetHeroine: 3
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun akhirnya sadar kalau dia menyesal tidak akrab
        dengan Miyu
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Miiyu Bulan 9 event part 3
    dialogueSteps:
    - sentenceText: '"Di saat itu pemain sadar betapa indah nya Miyu"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: Kamu tidak bisa menyerah, ya?
      voiceClip: {fileID: 8300000, guid: 6607ce4ce739c854d9e1b109532dc366, type: 3}
      speakingCharacterKey: Miyu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: Tidak akan
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: Kenapa? Apa Kamu tidak lelah menghadapi orang yang terus bersembunyi?
      voiceClip: {fileID: 8300000, guid: 4d7d748f33700184ca3579347d840f75, type: 3}
      speakingCharacterKey: Miyu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: Tidak. Karena aku tahu, di balik diam itu, ada seseorang yang
        menunggu dipahami
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: Aku takut. Takut jika aku membuka diri, aku akan kehilangan semuanya
      voiceClip: {fileID: 8300000, guid: 1abb11c22fdd1bc4ab13db5786ae6105, type: 3}
      speakingCharacterKey: Miyu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: Kau tidak kehilangan apa pun saat jujur. Kau justru mulai menemukan
        dirimu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: Aku tidak muu sendirian lagi
      voiceClip: {fileID: 8300000, guid: 62c5824a06a283147abbfb9ed55d5d5c, type: 3}
      speakingCharacterKey: Miyu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: Maka jangan
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 28f6491ce9a067540b77ce056ffd717c, type: 3}
      changeBackground: 1
    - sentenceText: "Apa Bolehkah aku tetap di sisimu\u2026 meskipun aku sering diam?"
      voiceClip: {fileID: 8300000, guid: fbf31dce9f00e11408eaaa66d4e0ed1f, type: 3}
      speakingCharacterKey: Miyu
