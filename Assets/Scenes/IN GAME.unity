      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Sudah waktunya masuk. Aku harus buru-buru ke kelas.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Jadi, aku pergi dulu, ya.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Oh iya, namaku Pemain.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
