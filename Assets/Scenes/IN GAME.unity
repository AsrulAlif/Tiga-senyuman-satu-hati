  dialogueLines:
  - dialogueID: Start
    dialogueSteps:
    - sentenceText: '"Pagi yang cerah..."'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"Hari pertama di SMA Gerberas."'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Pemain Bangun!!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: ini sudah jam tujuh!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Hari pertamamu di sekolah baru, kan?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Iya Bu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Ingat Senyum itu kuncinya mendapatkan teman.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Dan jangan lupa dimulai dari niat baik oke?.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Siap, Bu! Aku berangkat!
      nextDialogueID: s2
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun berangkat
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: malas banget sekolah baru
      nextDialogueID: s2
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun berangkat
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: s2
    dialogueSteps:
    - sentenceText: Hei!
      voiceClip: {fileID: 8300000, guid: b9af770ca90397e4897713b5b8554276, type: 3}
      speakingCharacterKey: 'Basrul '
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Hei! Kamu!
      voiceClip: {fileID: 8300000, guid: bf0da8fcaadee274db22ae6ae113267b, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Aku baru pertama kali liat kamu di sekolah ini.
      voiceClip: {fileID: 8300000, guid: f3f53e04dcfc5c84b9abe85f45988729, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Kamu anak baru, kan?
      voiceClip: {fileID: 8300000, guid: 9d7ad3c015cb1eb46bbd0f5705b0a98d, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: BTW, Aku Basrul!
      voiceClip: {fileID: 8300000, guid: f0c7b1752c3712b439b38c767e09602e, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Dan pasti kamu kelas 2-A kan?
      voiceClip: {fileID: 8300000, guid: 455bd93d935e8424b90c56e3db1a99fd, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Tunggu sebentar
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Ko Kamu tau?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Itu karena kita udah dapet bocoran kalau di kelas kita ada murid
        pindahan
      voiceClip: {fileID: 8300000, guid: 4b4ef24e970fa1f47b4340bc4f5c0a43, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Kita ngobrol nya di kelas aja
      voiceClip: {fileID: 8300000, guid: ac09923bbf0e93c45b3ecabe504043db, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: sini ikuti aku
      voiceClip: {fileID: 8300000, guid: acee8f286a00ae54d842e01be4c06db4, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Oh iya aku lupa nanya nama kamu
      voiceClip: {fileID: 8300000, guid: a9d72fa5ed37bdf4abfe727d87c24beb, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Nama mu siapa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aga telat ya...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Nama ku Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Selamat datang di SMA Gerberas kalo gitu
      voiceClip: {fileID: 8300000, guid: e21ef3ae2166a2e4ab3cf4faee55ad30, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Ngomong-ngomong kenapa kamu milih sekolah ini?
      voiceClip: {fileID: 8300000, guid: 6239461c0457e234f9391b9191a2d145, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Apa kah ada seseorang yang kamu ingin cari?
      voiceClip: {fileID: 8300000, guid: 25c7ef32f0189c640818957ba913ae14, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Seperti yang ada di manga-manga romance
      voiceClip: {fileID: 8300000, guid: 8a1be4a90992cb342bc830f27070f412, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kau terlalu menghayal basrul.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aku pilih sekolah ini karena ya dekat dengan rumah ku jalan 5
        menit langsung sampai.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aku tidak menyangka kalau kau itu wibu basrul
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kalo itu aku no debat.
      voiceClip: {fileID: 8300000, guid: b74ec641b192599468d12954793a15a8, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aku ada alasan kenapa aku menanya kan itu
      voiceClip: {fileID: 8300000, guid: 908146395948d95479c561ea8099047c, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Memang apa alasan nya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Itu karena di sekolah ini punya 3 top ratu kalo kau tau
      voiceClip: {fileID: 8300000, guid: 98cd563f43fd3de4ab65b79abd19b278, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kalo ga salah ada.... si galak,  si pemalu, dan si ceria.
      voiceClip: {fileID: 8300000, guid: 7a222f4957c16a14a957c87c301640c0, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Tapi katanya sih mereka susah didekati!
      voiceClip: {fileID: 8300000, guid: cba851c1bad6b874293c5d6e4d8940dd, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Tiga gadis populer ya... menarik.
      nextDialogueID: s3
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Aku ke sekolah bukan buat itu.
      nextDialogueID: Maya Bulan 1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: s3
    dialogueSteps:
    - sentenceText: Jadi kamu mau kemana abis ini pemain?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Perpustakaan mungkin
      nextDialogueID: Miyu 1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun pergi ke perpustakaan
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Mungkin aku mau bertanya sebentar
      nextDialogueID: Yumi1  Hikari1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: S3+
    dialogueSteps:
    - sentenceText: Aku harus kemana yaa untuk cari teman
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Ke Perpustakaan
      nextDialogueID: Miyu 1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun pergi ke perpustakaan
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Atau Mungkin aku bertanya sebentar ke Basrul
      nextDialogueID: Yumi1  Hikari1
