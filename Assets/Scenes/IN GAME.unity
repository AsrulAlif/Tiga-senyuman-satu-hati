      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 0}
      changeBackground: 0
    - sentenceText: Ada taman belakang buat santai, terus ada klub-klub yang rame
