      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Nanti istirahat gimana?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "kalau kamu mau\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: '"(diam sebentar)"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Bareng?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: jangan telat lagi ya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "Biar aku nggak perlu\u2026 nyari kamu lagi\u2026"
