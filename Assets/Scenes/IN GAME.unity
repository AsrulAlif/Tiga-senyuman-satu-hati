      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Miiyu Bulan 4-
    dialogueSteps:
    - sentenceText: '"Aku sudah tidak lama tidak bertemu Miyu"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: '"Terakhir aku bertemu sama dia, dia langsung lari"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: '"Padahal aku ingin bertemu"'
      voiceClip: {fileID: 0}
