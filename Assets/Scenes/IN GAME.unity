      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Jadi, ayo! Sebelum antrian es teh habis
      voiceClip: {fileID: 8300000, guid: 7202f7f071456d247b742e5a5f80741d, type: 3}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kau tak akan bisa menolak, bro. Sekali Hikari menawar, itu bukan
        tawaran itu Perintah
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
