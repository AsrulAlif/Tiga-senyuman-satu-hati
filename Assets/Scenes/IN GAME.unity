  - dialogueID: Miiyu Bulan 3 --
    dialogueSteps:
    - sentenceText: '"Sepertinya Miyu kelihatannya murung dan tidak bisa di ganggu"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: '"Ini jadi canggung untuk ngobrol dengannya"'
