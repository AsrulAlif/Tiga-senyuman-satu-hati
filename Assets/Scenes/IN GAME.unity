  - dialogueID: Miyu Bulan 2 event 1 part 4+
    dialogueSteps:
    - sentenceText: '"Aku belum makan bersama sama Miyu dan minta maaf"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
