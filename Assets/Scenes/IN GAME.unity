      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun membeli kan Kue untuk Yumi untuk permintaan
        maaf
      requiredMoodHeroine: 2
      requiredMoodPercent: 10
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Tidak peduli
      nextDialogueID: Yumi bulan 4-
      moodTargetHeroine: 2
      moodChangeAmount: -2
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Yumi bulan 3-
    dialogueSteps:
    - sentenceText: '"Aku jadi tidak terlalu dekat dengam Yumi aku tidak enak untuk
        makan bersama dengan Yumi"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Karena aku merasa tidak salah aku biar kan saja lah
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Tidak peduli
      nextDialogueID: Yumi Bulan 4-
      moodTargetHeroine: 2
      moodChangeAmount: -2
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Yumi Bulan 3
    dialogueSteps:
    - sentenceText: Halo Yumi
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Seperti biasa sibuk ya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Mau kubantu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kamu kenapa Yumi kamu ter lihat murung
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Yumi?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Hah?!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Oh ternyata kamu Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kamu dari tadi bengong.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Tidak juga.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Bukunya kebalik.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "\u2026!\u201D(langsung membalik buku dengan cepat)\""
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "Itu\u2026 cuma\u2026 lagi mikir!"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Mikir apa sampai segitu fokusnya?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "\u2026bukan urusan kamu"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Close up
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "Ini tentang \u2026tugas yang kemarin\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: '''Yang PR minggu lalu?'
      voiceClip: {fileID: 0}
      speakingCharacterKey: 
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 0}
      changeBackground: 0
    - sentenceText: 
      voiceClip: {fileID: 0}
      speakingCharacterKey: 
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 0}
      changeBackground: 0
    choices: []
