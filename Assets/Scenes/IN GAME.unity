      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 49998e9cc462cf946ab11720bec20e53, type: 3}
      changeBackground: 1
    - sentenceText: "A-ah\u2026 novel itu\u2026 s-sekuel dari yang kemarin aku baca\u2026"
