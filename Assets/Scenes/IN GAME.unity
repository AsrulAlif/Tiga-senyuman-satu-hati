      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Ka-kamu siapa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Aku Maya, dan ini dunia mimpi.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Dunia mimpi
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Bagaimana bisa
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Harusnya aku yang bertanya, kenapa kamu bisa di sini lagi?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Seharusnya kamu tidak berada di sini.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Aku juga tidak tahu.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Sebenarnya aku berusaha masuk ke mimpi ini, tapi sulit sekali.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Tentu saja, karena dunia mimpi ini memiliki waktu yang aneh.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Tapi..., Hem... Oh! Aku tahu kenapa kamu bisa di sini
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Mungkin karena di dunia nyata kamu terlalu lelah dan
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Karena energimu melemah di dunia nyata, sepertinya benang mimpinya
        terputus dan kamu ada di sini.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Dan aku tahu kenapa kamu kesulitan datang ke sini.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Itu karena apa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Sederhananya, satu hari di sini sama dengan satu bulan di dunia
        nyata.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Untuk sekarang, kamu perlu beristirahat.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Karena waktumu tidak banyak di sini.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Wah... "(menguap)" kok tiba-tiba aku mengantuk...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Aku akan menunggu, jadi...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Sampai jumpa, Pemain.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Tu...nggu aku, Ma...s
      nextDialogueID: Maya Bulan 2 event part 4
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
