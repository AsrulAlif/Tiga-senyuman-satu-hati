      returnDialogueAfterMiniGame: 
  - dialogueID: Hikari Bulan 6 event part 3
    dialogueSteps:
    - sentenceText: Akhir nya selesai
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
