      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: '"Heem aku ko tidak melihat dia masuk ya?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: '"Mingkin sudah di kelas"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
