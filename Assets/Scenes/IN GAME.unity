  notificationText: {fileID: 0}
  mainMenuSceneName: MainMenu
  moodManager: {fileID: 0}
  dialogueLines:
  - dialogueID: Start
    dialogueSteps:
    - sentenceText: '"Pagi yang cerah..."'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"Hari pertama di SMA Gerberas."'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Pemain, bangun!!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Ini sudah jam tujuh!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Hari pertamamu di sekolah baru, kan?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Iya Bu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Ingat, senyum itu kunci mendapatkan teman.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: Dan jangan lupa, mulai dengan niat baik, oke?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Ibu
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Siap, Bu! Aku berangkat!
      nextDialogueID: s2
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun berangkat
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Malas sekali masuk sekolah baru
      nextDialogueID: s2
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun berangkat
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: s2
    dialogueSteps:
    - sentenceText: Hei!
      voiceClip: {fileID: 8300000, guid: b9af770ca90397e4897713b5b8554276, type: 3}
      speakingCharacterKey: 'Basrul '
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Hei! Kamu!
      voiceClip: {fileID: 8300000, guid: bf0da8fcaadee274db22ae6ae113267b, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Aku baru pertama kali lihat kamu di sekolah ini.
      voiceClip: {fileID: 8300000, guid: f3f53e04dcfc5c84b9abe85f45988729, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Kamu anak baru, kan?
      voiceClip: {fileID: 8300000, guid: 9d7ad3c015cb1eb46bbd0f5705b0a98d, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Omong-omong, aku Basrul!
      voiceClip: {fileID: 8300000, guid: f0c7b1752c3712b439b38c767e09602e, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Dan pasti kamu kelas 2-A, kan?
      voiceClip: {fileID: 8300000, guid: 455bd93d935e8424b90c56e3db1a99fd, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Tunggu sebentar
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Kok kamu tahu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Itu karena kita sudah dapat bocoran kalau di kelas kita ada murid
        pindahan
      voiceClip: {fileID: 8300000, guid: 4b4ef24e970fa1f47b4340bc4f5c0a43, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Kita ngobrolnya di kelas saja.
      voiceClip: {fileID: 8300000, guid: ac09923bbf0e93c45b3ecabe504043db, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Sini, ikuti aku.
      voiceClip: {fileID: 8300000, guid: acee8f286a00ae54d842e01be4c06db4, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Oh iya, aku lupa bertanya namamu.
      voiceClip: {fileID: 8300000, guid: a9d72fa5ed37bdf4abfe727d87c24beb, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Namamu siapa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Agak telat, ya...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Namaku Pemain.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Selamat datang di SMA Gerberas kalau gitu
      voiceClip: {fileID: 8300000, guid: e21ef3ae2166a2e4ab3cf4faee55ad30, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Ngomong-ngomong, kenapa kamu memilih sekolah ini?
      voiceClip: {fileID: 8300000, guid: 6239461c0457e234f9391b9191a2d145, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Apakah ada seseorang yang ingin kamu cari?
      voiceClip: {fileID: 8300000, guid: 25c7ef32f0189c640818957ba913ae14, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Seperti yang ada di manga-manga romance
      voiceClip: {fileID: 8300000, guid: 8a1be4a90992cb342bc830f27070f412, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kau terlalu mengkhayal, Basrul.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aku memilih sekolah ini karena dekat dengan rumahku, hanya lima
        menit jalan kaki.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aku tidak menyangka kalau kau itu wibu, Basrul.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kalau itu aku tidak bisa membantah.
      voiceClip: {fileID: 8300000, guid: b74ec641b192599468d12954793a15a8, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Aku punya alasan kenapa menanyakan itu.
      voiceClip: {fileID: 8300000, guid: 908146395948d95479c561ea8099047c, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Memang apa alasannya?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Itu karena sekolah ini punya tiga ratu populer, kalau kau tahu.
      voiceClip: {fileID: 8300000, guid: 98cd563f43fd3de4ab65b79abd19b278, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kalau tidak salah ada... si galak, si pemalu, dan si ceria.
      voiceClip: {fileID: 8300000, guid: 7a222f4957c16a14a957c87c301640c0, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Tapi katanya sih mereka susah didekati!
      voiceClip: {fileID: 8300000, guid: cba851c1bad6b874293c5d6e4d8940dd, type: 3}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Tiga gadis populer ya... menarik.
      nextDialogueID: s3
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Aku ke sekolah bukan untuk itu.
      nextDialogueID: Maya Bulan 1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: s3
    dialogueSteps:
    - sentenceText: Jadi, kamu mau ke mana setelah ini, Pemain?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Perpustakaan mungkin
      nextDialogueID: Miyu 1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun pergi ke perpustakaan
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Mungkin aku mau bertanya sebentar
      nextDialogueID: Yumi1  Hikari1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: S3+
    dialogueSteps:
    - sentenceText: Aku harus ke mana, ya, untuk mencari teman?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Ke Perpustakaan
      nextDialogueID: Miyu 1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun pergi ke perpustakaan
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
    - choiceText: Atau Mungkin aku bertanya sebentar ke Basrul
      nextDialogueID: Yumi1  Hikari1
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 0
