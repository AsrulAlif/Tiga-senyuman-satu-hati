  - dialogueID: Hikari 2
    dialogueSteps:
    - sentenceText: Aku tidak ikut ikutan ya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Hei! Kau anak baru, kan? Aku Hikari!
      voiceClip: {fileID: 8300000, guid: 054271443d497f142945aebc18121a44, type: 3}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Ya, aku Pemain baru pindah minggu ini
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Uwah matahari datang
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Bagus bagus...Berarti aku punya alasan buat ngajakmu ke kantin!
      voiceClip: {fileID: 8300000, guid: ed541524c5f395144a203abb7d74392b, type: 3}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "Kau\u2026 selalu secerah ini?"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Nama nya juga matahari di kelas kita
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: ooh Tentu! Dunia ini terlalu suram kalau kita tidak menyalakan
        nya (Hahaha)
      voiceClip: {fileID: 8300000, guid: 0f797ee2c394f5240aafcc629a2536c7, type: 3}
