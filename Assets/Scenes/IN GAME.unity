      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Oh ya?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Iya! kaya Nggak bikin awkward gitu.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Jadi aku nggak bakal mikir dua kali buat ngajak kamu terus
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: 'Contoh nya hari ini '
