  - dialogueID: Miyu bulan 2 -1
    dialogueSteps:
    - sentenceText: '"Seperti nya aku keterlaluan sama Miyu"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
