      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: "\"(Kaget, langsung gugup)\"E-eh?! Ru-ruma kamu\u2026?"
      voiceClip: {fileID: 0}
