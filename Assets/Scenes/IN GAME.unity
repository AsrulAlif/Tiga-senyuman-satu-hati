      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Itu dia Yumi!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Apa kamu kemarin ke festival?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Tidak
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Marah
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Aku sedang sibuk dah
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Marah
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
