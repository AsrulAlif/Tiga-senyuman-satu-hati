  - dialogueID: Miiyu Bulan 9 event part 2-
    dialogueSteps:
    - sentenceText: '"Festival semalem sangat membosan kan"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"Aku penasaran apa miyu ke festival atau tidak kemarin"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: '"Heem aku ko tidak melihat dia masuk ya?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: '"Di perpustakaan juga ga ada"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: '"Di mana ya kira kira miyu"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Wadap Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Muka lesu banget kenapa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Aku sedang mencari Miyu,apa kamu liat Basrul?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Geregadewm lu ga tau?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Miyu kan akhir akhir ini dia tidak masuk
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Rumor nya dia mau pindah sekolah
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Maaf ya kawan ga ngabarin dari awal
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Iya ga papa Basrul trimakasih ya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Aman aja gua ke club dulu ya dah Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Daah...
      nextDialogueID: Miiyu Bulan 9 event part 3-
      moodTargetHeroine: 3
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
