  - dialogueID: Maya Bulan 2
    dialogueSteps:
    - sentenceText: '"Haah sudah sebulan penuh aku tidur siang tapi aku belum menemukan
        mimpi yang sama"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"Aku perlu bantuan"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"Apa Basrul tahu soal ini?"'
      voiceClip: {fileID: 0}
