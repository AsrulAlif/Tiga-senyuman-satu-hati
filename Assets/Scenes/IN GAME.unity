      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 49998e9cc462cf946ab11720bec20e53, type: 3}
      changeBackground: 1
    - sentenceText: "I-iya biasanya\u2026 aku sendiri\u2026 ke sini"
