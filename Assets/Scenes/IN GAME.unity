    - choiceText: Tidur lagi nanti
      nextDialogueID: Maya Bulan 2
      moodTargetHeroine: 0
      moodChangeAmount: 0
      moneyChange: 20000
      endOfMonth: 1
      triggerNormalTransition: 0
