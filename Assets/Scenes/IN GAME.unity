      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Mungkin baru kali ini baru sadar
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Nyari aku?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: "Kalau kamu nggak ada\u2026 kamu Pemain"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: "perpustakaan jadi terasa\u2026 lebih sepi\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: "E-eh?! M-maaf! A-aku ngomong aneh ya\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Nggak kok
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Kenapa aku harus marah
