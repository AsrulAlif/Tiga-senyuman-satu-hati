      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: aa1f6d4654b77654aaff24713c7893d6, type: 3}
      changeBackground: 1
    - sentenceText: Mereka mengenalku itu karena aku itu aneh
      voiceClip: {fileID: 0}
