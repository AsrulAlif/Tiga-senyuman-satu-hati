  - dialogueID: Maya Bulan 3 event part 1
    dialogueSteps:
    - sentenceText: Ini kan
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Mimpi yang bulan lalu...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Yess... berhasil
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Kamu datang lagi ke sini, Pemain. Aku jadi senang.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Biasanya ini tidak terjadi dua kali.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Kamu Maya?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Iya, aku Maya. Kenapa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Rambutmu kok panjang?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Ini kan dunia mimpi
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Dan aku penjaga di sini. Tentu saja aku bebas melakukan apa saja
        di sini.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Lihat ini
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Panjang
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Pendek
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Panjang
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Pendek
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Pendek
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Panjang
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Apa aku juga bisa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Kalau itu, kamu tidak bisa.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Kenapa tidak bisa?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Ya... karena ini bukan dunia mimpimu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Jadi, kenapa kamu ke sini lagi?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Oh iya... kenapa kamu bisa tahu namaku?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Itu saja?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Ya itu karena aku penjaga dunia mimpi ini tentu saja aku tahu
        kamu siapa
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Wah, sepertinya waktumu hampir habis lagi.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Oh tidak, aku mengantuk...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Jangan dipaksakan. Sudah, tutup saja matamu.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    - sentenceText: Sampai jumpa lagi Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Maya
      activeCharacterKeys: Maya Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: ab6979896141a04438b11989a02ed2c3, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Tu...nggu aku, Ma...s
