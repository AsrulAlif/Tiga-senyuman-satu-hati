  - dialogueID: Yumi1  Hikari1
    dialogueSteps:
    - sentenceText: Aku mau tanya Basrul
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Memang Yumi se galak itu?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Kamu harus berhati hati karena yumi itu...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Basrul
      activeCharacterKeys: Basrul Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: "Kalian\u2026 sedang membicarakan siapa?"
      voiceClip: {fileID: 8300000, guid: 49e8e3ba4fcf37845897cd25ec3b8f1b, type: 3}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
