  - dialogueID: Miiyu Bulan 7
    dialogueSteps:
    - sentenceText: '"Di mana ya Miyu"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: '"Kata nya mau ketemuan di taman"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: '"Apa aku dateng nya kecepetan ya?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: "A-ah\u2026 kamu sudah sampai apa kamu menunggu lama?"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: Tidak kok aku baru sampai
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: "Syukurlah\u2026\"(sedikit lega)\""
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: ...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: "\"(Menunduk sedikit)\"\u2026u-um\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: '?'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: "A-apa\u2026 aku terlihat aneh\u2026?"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: Tidak kok, kamu keliatan Cantik dan rapih hari ini.
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: "E-eh\u2026 C-cantik\u2026? \"(kaget, lalu wajah merah)\""
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: '"(Miyu Menutupi setengah muka nya dengan tas)"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: "T-terima kasih\u2026 Pemain"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: Kamu siap?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
      changeBackground: 1
    - sentenceText: "I-iya\u2026"
      voiceClip: {fileID: 0}
      speakingCharacterKey: Miyu
      activeCharacterKeys: Miyu Biasa date
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 1426c481b1eb2e54d909793ac1fc1184, type: 3}
