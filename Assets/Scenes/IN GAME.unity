      backgroundImage: {fileID: 21300000, guid: 99450402e96793240a00bd1e96c1861b, type: 3}
      changeBackground: 1
    - sentenceText: Apa kamu pergi sendirian apa sama orang lain?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99450402e96793240a00bd1e96c1861b, type: 3}
      changeBackground: 1
    - sentenceText: Heem.... kenapa kamu menanya kan itu?
