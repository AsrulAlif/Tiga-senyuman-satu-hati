      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: Ga masalah tapi ga lama kan kamu nunggu nya
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa festival
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: ...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: Oooi Pemain
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa festival
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: Maaf aku baru saja melihat matahari di malam hari ini
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: Apa sih kamu,ayo cepat kita liat-liat
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa festival
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Iya iyaa sabar
      nextDialogueID: Hikari Bulan 8 event part 1
      moodTargetHeroine: 1
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain dan Hikari pun makan bersama, menikmati jalan
        jalan dan bersenang senang bersama
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Hikari Bulan 9-
    dialogueSteps:
    - sentenceText: '"Haah festival ini terasa membosankan"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: '"Harus kah aku bermain di sana?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: '"Bermain"'
      nextDialogueID: Hikari Bulan 9 event part 1-
      moodTargetHeroine: 1
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 1
      miniGameSceneName: MiniGame Yumi-
      returnDialogueAfterMiniGame: Hikari Bulan 9 event part 1-
  - dialogueID: Hikari Bulan 9 event part 1
    dialogueSteps:
    - sentenceText: Lihat ada permainan apa kamu mau main Hikari?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: Kamu aja aku terlau jago dan bosan sama permainan itu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa festival
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: Aku akan lihat seberapa hebat kamu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa festival
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: '"Bermain"'
      nextDialogueID: Hikari Bulan 9 event part 2
      moodTargetHeroine: 1
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 1
      miniGameSceneName: MiniGame 2
      returnDialogueAfterMiniGame: Hikari Bulan 9 event part 2
  - dialogueID: Hikari Bulan 9 event part 1-
    dialogueSteps:
    - sentenceText: '"Ini sangat membosankan"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: '"Apa aku perlu bermain lagi?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: '"Bermain lagi"'
      nextDialogueID: Hkari Bulan 9 event part 1-
      moodTargetHeroine: 1
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 1
      miniGameSceneName: MiniGame Hikari-
      returnDialogueAfterMiniGame: Hikari Bulan 9 event part 1-
    - choiceText: '"Pulang"'
      nextDialogueID: Hkari Bulan 9 event part 2-
      moodTargetHeroine: 3
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Karena Pemain merasa bosan di festival Pemain pun pulang
        dan Pemain melihat Hikari sedang bersama teman-teman nya
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Hikari Bulan 9 event part 2
    dialogueSteps:
    - sentenceText: Wah tadi seru banget
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    - sentenceText: Apa kamu mau bermain lagi Pemain?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa festival
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 93cdbc676d868ea478851aa95a914ca0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Bermain
      nextDialogueID: Hikari Bulan 9 event part 2
      moodTargetHeroine: 1
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 1
      miniGameSceneName: MiniGame 2
      returnDialogueAfterMiniGame: Hikari Bulan 9 event part 2
    - choiceText: Tidak, ayo kita liat kembang api
      nextDialogueID: Hikari Bulan 9 event part 3
      moodTargetHeroine: 1
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain dan Hikari pun pergi ke tempat yang cocok untuk
        melihat kembang api
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Hikari Bulan 9 event part 2-
    dialogueSteps:
    - sentenceText: '"Festival semalem sangat membosan kan"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    - sentenceText: '"Aku penasaran apa Hikari di festival lihat aku apa tidak ya?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: '"Heem aku ko tidak melihat dia masuk ya?"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: '"Mingkin sudah di kelas"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: cd8e6cf153780c4479a61f1c32f41885, type: 3}
      changeBackground: 1
    - sentenceText: Itu dia, Hikari!
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Apa kamu lihat aku festival?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: f55b01f803d771548901bb361fe3bb04, type: 3}
      changeBackground: 1
    - sentenceText: Heem...
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Marah
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Tidak
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Marah
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    - sentenceText: Aku Pergi dulu ya Pemain daaah
      voiceClip: {fileID: 0}
      speakingCharacterKey: Yumi
      activeCharacterKeys: Yumi Marah
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 04073754593a83042b561d10c04a146c, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Daah...
      nextDialogueID: Hikari Bulan 9 event part 3-
      moodTargetHeroine: 3
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 1
      normalTransitionText: Pemain pun akhir nya sadar kalo dia menyesal tidak akrab
        dengan Hikari
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 0
      miniGameSceneName: 
      returnDialogueAfterMiniGame: 
  - dialogueID: Hikari Bulan 9 event part 3
    dialogueSteps:
    - sentenceText: '"Saat aku melihat Hikari memgeluarkan air mata"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: Apa kamu tak apa Hikari?
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: "Jangan\u2026 aku bisa membuatmu repot"
      voiceClip: {fileID: 8300000, guid: eb6d64da51173f945958ec38e88e737a, type: 3}
      speakingCharacterKey: Hikari
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: Repot karena peduli itu bukanlah beban Hikari
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: Apa kamu benar-benar tidak takut melihatku tanpa tawa?
      voiceClip: {fileID: 8300000, guid: 8394469ef61edba4da2731ea73fe016c, type: 3}
      speakingCharacterKey: Hikari
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: Aku ingin mengenalmu bukan karena tawamu, tapi karena hatimu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: "Aku ingin tertawa lagi,aku ingin. Tapi kali ini\u2026 karena
        aku ingin bahagia, bukan karena harus"
      voiceClip: {fileID: 8300000, guid: 498848423e4d62e42ad0e51c1fbff702, type: 3}
      speakingCharacterKey: Hikari
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: Maka kita hanya perlu bersama kan
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: "Aku ingin tertawa lagi,aku ingin. Tapi kali ini\u2026 karena
        aku ingin bahagia, bukan karena harus"
      voiceClip: {fileID: 8300000, guid: cf530f8f5085ce242826e048e9df7038, type: 3}
      speakingCharacterKey: Hikari
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: Dan aku hanya beruntung bisa menjadi langit itu
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: "Jadi\u2026 jangan biarkan aku kehilangan cahaya ini lagi yaa..."
      voiceClip: {fileID: 8300000, guid: 42eb43d5d729e654e8e9e44dc99aeaab, type: 3}
      speakingCharacterKey: Hikari
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    - sentenceText: '"(Hikari terdiam. Cahaya kembang api memantul di matanya.)"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Hikari
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 0857a6111aa07184d946e555d20e75d4, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Tidak akan
      nextDialogueID: Tamat
      moodTargetHeroine: 1
      moodChangeAmount: 3
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 1
      miniGameSceneName: Ending
      returnDialogueAfterMiniGame: 
  - dialogueID: Hikari Bulan 9 event part 3-
    dialogueSteps:
    - sentenceText: '"Andai saja aku akrab dengan nya"'
      voiceClip: {fileID: 0}
      speakingCharacterKey: Pemain
      activeCharacterKeys: 
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 21300000, guid: 99517b0d7c32efa49a7bc7e10784b0c0, type: 3}
      changeBackground: 1
    choices:
    - choiceText: Aku menyesal sekali
      nextDialogueID: Tamat
      moodTargetHeroine: 1
      moodChangeAmount: 0
      moneyChange: 0
      endOfMonth: 0
      triggerNormalTransition: 0
      normalTransitionText: 
      requiredMoodHeroine: 0
      requiredMoodPercent: 0
      moodInsufficientMessage: 
      loadMiniGameScene: 1
      miniGameSceneName: Ending
      returnDialogueAfterMiniGame: 
