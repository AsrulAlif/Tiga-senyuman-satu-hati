      speakingCharacterKey: Hikari
      activeCharacterKeys: Hikari Biasa
      iconSprite: {fileID: 0}
      backgroundImage: {fileID: 0}
      changeBackground: 0
    - sentenceText: 'Kapan kapan kita nyoba makanan lain apa kamu mau? tapi jangan
